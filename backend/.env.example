# ========================================
# Environment Variables Example
# ========================================

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/deepguard

# JWT
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# App
APP_NAME=DeepGuard
DEBUG=True
UPLOAD_DIR=uploads
